<% content_for :title, "Session Expired" %>

<div class="min-h-screen bg-gray-950 text-gray-100 flex items-center justify-center px-6">
  <div class="max-w-md w-full text-center">
    <div class="w-16 h-16 bg-yellow-950 border border-yellow-800 rounded-full flex items-center justify-center mx-auto mb-6">
      <svg class="w-8 h-8 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
      </svg>
    </div>

    <h1 class="text-2xl font-bold text-white mb-2">Session Expired</h1>
    <p class="text-gray-400 text-sm mb-6">
      Your LTI session has expired or is no longer valid. Please re-launch this tool from Canvas to continue.
    </p>

    <div class="bg-gray-900 border border-gray-800 rounded-xl p-4 text-sm text-gray-500">
      This tool must be launched directly from your Canvas course — it cannot be accessed by direct URL.
    </div>
  </div>
</div>
