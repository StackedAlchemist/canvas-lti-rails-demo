<% content_for :title, "StrongMind LTI Demo" %>

<div class="min-h-screen bg-gray-950 text-gray-100 flex items-center justify-center px-6">
  <div class="max-w-lg w-full">

    <%# Header %>
    <div class="text-center mb-10">
      <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-900 border border-blue-700 rounded-2xl mb-5">
        <svg class="w-8 h-8 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.746 0 3.332.477 4.5 1.253v13C19.832 18.477 18.246 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
        </svg>
      </div>
      <h1 class="text-3xl font-bold text-white mb-2">StrongMind LTI Demo</h1>
      <p class="text-gray-400 text-sm">
        LTI 1.3 · Grade Passback · Versioned Content · AI Study Assistant
      </p>
    </div>

    <%# Launch Simulator %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 mb-6">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4">Simulate LTI Launch</p>
      <p class="text-gray-400 text-sm mb-5">
        In production this app is launched from inside Canvas. Use the buttons below to simulate
        a launch and explore the app without Canvas.
      </p>

      <div class="grid grid-cols-2 gap-3">
        <%= link_to simulate_launch_path(role: "student"),
              class: "flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white font-semibold py-3 px-4 rounded-xl transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
          </svg>
          Launch as Student
        <% end %>

        <%= link_to simulate_launch_path(role: "teacher"),
              class: "flex items-center justify-center gap-2 bg-emerald-700 hover:bg-emerald-600 text-white font-semibold py-3 px-4 rounded-xl transition-colors" do %>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                  d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
          </svg>
          Launch as Teacher
        <% end %>
      </div>
    </div>

    <%# What's Inside %>
    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 mb-6">
      <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4">What's Inside</p>
      <ul class="space-y-2 text-sm text-gray-400">
        <li class="flex items-start gap-2">
          <span class="text-blue-400 mt-0.5">✓</span>
          <span><strong class="text-gray-200">Student dashboard</strong> — progress tracking, grade display, assignment status</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-blue-400 mt-0.5">✓</span>
          <span><strong class="text-gray-200">Versioned content authoring</strong> — drafts never break the live student view</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-blue-400 mt-0.5">✓</span>
          <span><strong class="text-gray-200">Grade passback (AGS)</strong> — scores sent to Canvas gradebook via Sidekiq</span>
        </li>
        <li class="flex items-start gap-2">
          <span class="text-blue-400 mt-0.5">✓</span>
          <span><strong class="text-gray-200">AI study assistant</strong> — Claude-powered chat with course context awareness</span>
        </li>
      </ul>
    </div>

    <%# Footer %>
    <div class="text-center">
      <p class="text-xs text-gray-600">
        LTI endpoints active at
        <code class="text-gray-500">POST /lti/login</code> ·
        <code class="text-gray-500">POST /lti/launch</code> ·
        <code class="text-gray-500">GET /.well-known/jwks.json</code>
      </p>
      <p class="text-xs text-gray-700 mt-2">
        Built by Billy Williams · Stacked Alchemist LLC · stackedalchemist.dev
      </p>
    </div>

  </div>
</div>
